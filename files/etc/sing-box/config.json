{
  "log": {
    "level": "info"
  },

  "dns": {
    "servers": [
      { "tag": "cf", "address": "https://1.1.1.1/dns-query" },
      { "tag": "google", "address": "tls://8.8.8.8" },
      { "tag": "local", "address": "223.5.5.5" }
    ],
    "rules": [
      { "domain_suffix": ["cn"], "server": "local" }
    ]
  },

  "inbounds": [
    {
      "type": "tun",
      "interface_name": "tun0",
      "auto_route": true,
      "strict_route": true
    }
  ],

  "outbounds": [
    {
      "type": "selector",
      "tag": "auto",
      "outbounds": ["node1", "node2", "node3"]
    },

    {
      "type": "vmess",
      "tag": "node1",
      "server": "你的节点1",
      "server_port": 443,
      "uuid": "xxxx",
      "security": "auto"
    },

    {
      "type": "shadowsocks",
      "tag": "node2",
      "server": "你的节点2",
      "server_port": 8388,
      "method": "aes-128-gcm",
      "password": "xxxx"
    },

    {
      "type": "vless",
      "tag": "node3",
      "server": "你的节点3",
      "server_port": 443,
      "uuid": "xxxx"
    },

    {
      "type": "direct",
      "tag": "direct"
    }
  ],

  "route": {
    "auto_detect_interface": true,
    "rules": [
      { "geoip": ["cn"], "outbound": "direct" },

      { "domain_keyword": ["openai", "claude"], "outbound": "auto" },

      { "domain_keyword": ["netflix", "disney"], "outbound": "auto" },

      { "protocol": "dns", "outbound": "direct" }
    ]
  }
}
