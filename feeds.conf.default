# feeds.conf
# OpenWRT 25.12 feeds configuration
# 适配 Ubuntu 24.04 编译环境

# ═══════════════════════════════════════════════════════════════
# Passwall 源（必须在官方源之前，确保优先级）
# ═══════════════════════════════════════════════════════════════
src-git passwall_packages https://github.com/Openwrt-Passwall/openwrt-passwall-packages.git;main
src-git passwall_luci https://github.com/Openwrt-Passwall/openwrt-passwall.git;main

# ═══════════════════════════════════════════════════════════════
# 官方源
# ═══════════════════════════════════════════════════════════════
src-git packages https://git.openwrt.org/feed/packages.git;openwrt-25.12
src-git luci https://git.openwrt.org/feed/luci.git;openwrt-25.12
src-git routing https://git.openwrt.org/feed/routing.git;openwrt-25.12
src-git telephony https://git.openwrt.org/feed/telephony.git;openwrt-25.12

# ═══════════════════════════════════════════════════════════════
# 第三方源
# ═══════════════════════════════════════════════════════════════
src-git openclash https://github.com/vernesong/OpenClash.git;master
src-git argon https://github.com/jerrykuku/luci-theme-argon.git;master

