# ============================================================
# GL-MT3000 (Beryl AX) 官方功能复刻 + 安全强化版
# ============================================================

# [1] 硬件驱动：官方 Wi-Fi 与 蓝牙/USB 性能
CONFIG_PACKAGE_kmod-mt7981-firmware=y
CONFIG_PACKAGE_wpad-mesh-mbedtls=y       # 支持 802.11s Mesh (官方 Mesh 功能基础)
CONFIG_PACKAGE_kmod-usb3=y
CONFIG_PACKAGE_kmod-usb-storage-uas=y    # 提升 USB 3.0 硬盘速度
CONFIG_PACKAGE_kmod-usb-net-rtl8152=y    # 支持官方常用的 USB 网卡扩展

# [2] 官方核心网络功能：中继、拨号与负载均衡
CONFIG_PACKAGE_luci-app-mwan3=y           # 官方“多WAN/中继切换”功能的核心
CONFIG_PACKAGE_luci-app-syncdial=y       # 多拨支持
CONFIG_PACKAGE_luci-app-sqm=y             # 官方“智能队列管理/QoS”
CONFIG_PACKAGE_luci-app-upnp=y           # 官方默认开启的 UPnP (您可按需在界面关闭)

# [3] 官方存储与文件共享 (NAS 功能)
CONFIG_PACKAGE_luci-app-samba4=y          # 官方“文件共享”
CONFIG_PACKAGE_luci-app-diskman=y         # 磁盘管理界面
CONFIG_PACKAGE_kmod-fs-ntfs3=y           # 官方支持的 NTFS 读写优化
CONFIG_PACKAGE_kmod-fs-exfat=y           # SD卡/U盘常用格式

# [4] 官方 VPN 协议全支持
CONFIG_PACKAGE_luci-app-wireguard=y      # 官方主打的 WireGuard
CONFIG_PACKAGE_luci-app-openvpn=y        # 官方 OpenVPN 支持
CONFIG_PACKAGE_luci-app-zerotier=y       # 官方支持的异地组网

# [5] 物理开关与 LED 控制 (重要！)
# 官方侧边开关通常用于控制 VPN 或 Wi-Fi，需通过自定义脚本实现，配置如下：
CONFIG_PACKAGE_kmod-gpio-button-hotplug=y
CONFIG_PACKAGE_luci-app-ledtrig-rssi=y   # 信号强度灯光支持

# [6] 您的安全强化与代理插件 (保持不变)
CONFIG_PACKAGE_luci-app-openclash=y
CONFIG_PACKAGE_luci-app-passwall=y
CONFIG_PACKAGE_luci-app-adblock-fast=y
CONFIG_PACKAGE_firewall4=y
CONFIG_PACKAGE_dnsmasq-full=y

# [7] 性能工具 (官方后台有的系统状态统计)
CONFIG_PACKAGE_luci-app-statistics=y     # 官方“系统状态”图表
CONFIG_PACKAGE_luci-app-ttyd=y           # 网页终端
