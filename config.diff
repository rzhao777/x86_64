# ============================================================
# OpenWrt 25.12 x86_64 通用 + 强化安全版 config.diff
# 官方默认 + OpenVPN + OpenClash + Passwall + Argon主题
# 适用于虚拟机 + 物理机，注重安全与隐私
# ============================================================

# ===== 目标平台配置 =====
CONFIG_TARGET_x86=y
CONFIG_TARGET_x86_64=y
CONFIG_TARGET_x86_64_DEVICE_generic=y
CONFIG_VMDK_IMAGES=y

# ===== 系统功能特性 =====
CONFIG_TARGET_ROOTFS_SQUASHFS=y
CONFIG_TARGET_ROOTFS_EXT4FS=y
CONFIG_TARGET_IMAGES_GZIP=y

# ===== GRUB 引导程序 =====
CONFIG_GRUB_IMAGES=y
CONFIG_GRUB_EFI_IMAGES=y
CONFIG_GRUB_CONSOLE=y
CONFIG_GRUB_BAUDRATE=115200
CONFIG_GRUB_FLOWCONTROL=y
CONFIG_GRUB_TIMEOUT=5
CONFIG_GRUB_TITLE="OpenWrt Secure"
CONFIG_TARGET_KERNEL_PARTSIZE=1024
CONFIG_TARGET_ROOTFS_PARTSIZE=4096

# ===== 基础系统包 =====
CONFIG_PACKAGE_base-files=y
CONFIG_PACKAGE_ca-bundle=y
CONFIG_PACKAGE_ca-certificates=y
CONFIG_PACKAGE_coreutils-sort=y
CONFIG_PACKAGE_dropbear=y
CONFIG_PACKAGE_intel-microcode=y
CONFIG_PACKAGE_iucode-tool=y
CONFIG_PACKAGE_libopenssl=y
CONFIG_PACKAGE_libopenssl-conf=y
CONFIG_PACKAGE_libuci=y
CONFIG_PACKAGE_libustream-openssl=y
CONFIG_PACKAGE_mtd=y
CONFIG_PACKAGE_opkg=y
CONFIG_PACKAGE_uci=y

# ===== 网络驱动（通用兼容 + 减少攻击面） =====
CONFIG_PACKAGE_kmod-e1000=y
CONFIG_PACKAGE_kmod-e1000e=y
CONFIG_PACKAGE_kmod-igb=y
CONFIG_PACKAGE_kmod-igc=y
CONFIG_PACKAGE_kmod-r8169=y
CONFIG_PACKAGE_kmod-vmxnet3=y
CONFIG_PACKAGE_kmod-virtio-net=y
CONFIG_PACKAGE_kmod-virtio-pci=y
CONFIG_PACKAGE_kmod-tun=y
CONFIG_PACKAGE_kmod-virtio-balloon=y
CONFIG_PACKAGE_qemu-ga=y

# 磁盘驱动
CONFIG_PACKAGE_kmod-scsi-core=y
CONFIG_PACKAGE_kmod-scsi-generic=y
CONFIG_PACKAGE_kmod-libata=y
CONFIG_PACKAGE_kmod-ata-piix=y

# 显示与 USB
CONFIG_PACKAGE_kmod-drm-i915=y
CONFIG_PACKAGE_kmod-usb-core=y
CONFIG_PACKAGE_kmod-usb-ohci=y
CONFIG_PACKAGE_kmod-usb-ehci=y
CONFIG_PACKAGE_kmod-usb-xhci=y
CONFIG_PACKAGE_kmod-usb-storage=y

# 文件系统
CONFIG_PACKAGE_block-mount=y
CONFIG_PACKAGE_kmod-fs-ext4=y

# ===== 官方防火墙（firewall4 + nftables） =====
CONFIG_PACKAGE_firewall4=y
CONFIG_PACKAGE_nftables=y
CONFIG_PACKAGE_nftables-json=y
CONFIG_PACKAGE_luci-app-firewall=y

# nftables 内核模块
CONFIG_PACKAGE_kmod-nft-core=y
CONFIG_PACKAGE_kmod-nft-fib=y
CONFIG_PACKAGE_kmod-nft-nat=y
CONFIG_PACKAGE_kmod-nft-offload=y
CONFIG_PACKAGE_kmod-nf-offload=y

# ===== DHCP/DNS & Adblock =====
CONFIG_PACKAGE_dnsmasq-full=y
CONFIG_PACKAGE_dnsmasq_full_auth=y
CONFIG_PACKAGE_dnsmasq_full_conntrack=y
CONFIG_PACKAGE_dnsmasq_full_dhcp=y
CONFIG_PACKAGE_dnsmasq_full_dhcpv6=y
CONFIG_PACKAGE_dnsmasq_full_dnssec=y
CONFIG_PACKAGE_dnsmasq_full_ipset=y
CONFIG_PACKAGE_dnsmasq_full_noid=y
CONFIG_PACKAGE_dnsmasq_full_tftp=y

CONFIG_PACKAGE_adblock-fast=y
CONFIG_PACKAGE_luci-app-adblock-fast=y
CONFIG_PACKAGE_luci-i18n-adblock-fast-zh-cn=y

# ===== 分区工具 & IPv6 & PPP =====
CONFIG_PACKAGE_partx-utils=y
CONFIG_PACKAGE_blkid=y
CONFIG_PACKAGE_e2fsprogs=y
CONFIG_PACKAGE_mkf2fs=y
CONFIG_PACKAGE_resize2fs=y

CONFIG_IPV6=y
CONFIG_PACKAGE_odhcp6c=y
CONFIG_PACKAGE_odhcpd-ipv6only=y

CONFIG_PACKAGE_ppp=y
CONFIG_PACKAGE_ppp-mod-pppoe=y

# ===== OpenVPN =====
CONFIG_PACKAGE_openvpn-openssl=y
CONFIG_PACKAGE_openvpn-easy-rsa=y
CONFIG_PACKAGE_luci-app-openvpn=y

# ===== OpenSSL 强化 =====
CONFIG_OPENSSL_WITH_TLS13=y
CONFIG_OPENSSL_WITH_CAMELLIA=y
CONFIG_OPENSSL_WITH_ARIA=y
CONFIG_OPENSSL_WITH_CHACHA_POLY1305=y
CONFIG_OPENSSL_WITH_PSK=y
# CONFIG_OPENSSL_WITH_WEAK_SSL_CIPHERS is not set
CONFIG_PACKAGE_openssl-util=y

# ===== LuCI 与主题 =====
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-app-firewall=y
CONFIG_PACKAGE_luci-app-opkg=y
CONFIG_PACKAGE_luci-ssl-openssl=y
CONFIG_PACKAGE_luci-mod-admin-full=y
CONFIG_PACKAGE_luci-theme-bootstrap=y

# Argon 主题
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_luci-app-argon-config=y

# ===== OpenClash =====
CONFIG_PACKAGE_openclash=y
CONFIG_PACKAGE_luci-app-openclash=y
CONFIG_PACKAGE_clash=y
CONFIG_PACKAGE_clash-meta=y

# OpenClash 依赖
CONFIG_PACKAGE_bash=y
CONFIG_PACKAGE_coreutils=y
CONFIG_PACKAGE_coreutils-nohup=y
CONFIG_PACKAGE_jq=y
CONFIG_PACKAGE_jsonfilter=y
CONFIG_PACKAGE_resolveip=y
CONFIG_PACKAGE_gawk=y

# ===== Passwall =====
CONFIG_PACKAGE_passwall=y
CONFIG_PACKAGE_luci-app-passwall=y
CONFIG_PACKAGE_passwall_compatible_packages=y

# Shadowsocks / V2Ray / Xray / Trojan 等
CONFIG_PACKAGE_shadowsocks-libev=y
CONFIG_PACKAGE_shadowsocks-rust=y
CONFIG_PACKAGE_shadowsocks-libev-ss-local=y
CONFIG_PACKAGE_shadowsocks-libev-ss-redir=y
CONFIG_PACKAGE_v2ray-core=y
CONFIG_PACKAGE_v2ray-geoip=y
CONFIG_PACKAGE_v2ray-geosite=y
CONFIG_PACKAGE_xray-core=y
CONFIG_PACKAGE_trojan=y
CONFIG_PACKAGE_hysteria=y
CONFIG_PACKAGE_naive=y
CONFIG_PACKAGE_redsocks2=y

# Passwall 依赖
CONFIG_PACKAGE_c-ares=y
CONFIG_PACKAGE_pcre=y
CONFIG_PACKAGE_mbedtls=y
CONFIG_PACKAGE_nghttp2=y
CONFIG_PACKAGE_http-parser=y

# ===== 网络优化 =====
CONFIG_PACKAGE_kmod-tcp-bbr=y
CONFIG_PACKAGE_kmod-sched-core=y
CONFIG_PACKAGE_kmod-sched-cake=y

# ===== 系统工具 & 中文支持 =====
CONFIG_PACKAGE_logd=y
CONFIG_PACKAGE_urandom=y
CONFIG_PACKAGE_sed=y
CONFIG_PACKAGE_grep=y
CONFIG_PACKAGE_awk=y
CONFIG_PACKAGE_gzip=y
CONFIG_PACKAGE_unzip=y
CONFIG_PACKAGE_nano=y
CONFIG_PACKAGE_vim=y
CONFIG_PACKAGE_ntpd=y
CONFIG_PACKAGE_ntpdate=y
CONFIG_PACKAGE_zoneinfo-china=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget-ssl=y
CONFIG_PACKAGE_openssh-client=y
CONFIG_PACKAGE_file=y
CONFIG_PACKAGE_tar=y
CONFIG_PACKAGE_bind-dig=y
CONFIG_PACKAGE_iputils-traceroute=y
CONFIG_PACKAGE_mtr=y
CONFIG_PACKAGE_netcat-openbsd=y
CONFIG_PACKAGE_open-vm-tools=y

# 禁用不必要服务
# CONFIG_PACKAGE_miniupnpd is not set
# CONFIG_PACKAGE_luci-app-upnp is not set

# 中文语言
CONFIG_LUCI_LANG_zh_Hans=y
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y
CONFIG_PACKAGE_luci-i18n-status-zh-cn=y
CONFIG_PACKAGE_luci-i18n-firewall-zh-cn=y
CONFIG_PACKAGE_luci-i18n-opkg-zh-cn=y
CONFIG_PACKAGE_luci-i18n-openvpn-zh-cn=y
CONFIG_PACKAGE_luci-i18n-ttyd-zh-cn=y
CONFIG_PACKAGE_luci-i18n-argon-config-zh-cn=y
CONFIG_PACKAGE_luci-i18n-passwall-zh-cn=y

# 25.12 必备
CONFIG_PACKAGE_luci-app-package-manager=y
CONFIG_PACKAGE_apk-openssl=y

# ===== 编译优化 =====
CONFIG_CCACHE=y
CONFIG_KERNEL_KALLSYMS=n
CONFIG_KERNEL_DEBUG_INFO=n
CONFIG_STRIP_KERNEL_EXPORTS=y

# ===== 内核基础配置 =====
CONFIG_KERNEL_SWAP=y
CONFIG_KERNEL_SYN_COOKIES=y
CONFIG_KERNEL_DEFAULT_TCP_CONG="bbr"
CONFIG_KERNEL_PRINTK=y

# ===== 内核安全强化（核心部分） =====
CONFIG_KERNEL_STACKPROTECTOR=y
CONFIG_KERNEL_STACKPROTECTOR_STRONG=y
CONFIG_KERNEL_PAGE_TABLE_ISOLATION=y
CONFIG_KERNEL_HARDENED_USERCOPY=y
CONFIG_KERNEL_SLAB_FREELIST_RANDOM=y
CONFIG_KERNEL_SLAB_FREELIST_HARDENED=y
CONFIG_KERNEL_REFCOUNT_FULL=y
CONFIG_KERNEL_SECURITY=y
CONFIG_KERNEL_SECURITY_NETWORK=y
CONFIG_KERNEL_SECURITY_NETWORK_XFRM=y
CONFIG_KERNEL_SECURITY_YAMA=y
CONFIG_KERNEL_LSM="landlock,lockdown,yama"

CONFIG_KERNEL_GCC_PLUGIN_STRUCTLEAK=y
CONFIG_KERNEL_GCC_PLUGIN_STRUCTLEAK_BYREF_ALL=y
CONFIG_KERNEL_GCC_PLUGIN_STACKLEAK=y

# 额外高价值内核强化（推荐开启）
CONFIG_RANDOMIZE_BASE=y
CONFIG_RANDOMIZE_MEMORY=y
CONFIG_INIT_ON_ALLOC_DEFAULT_ON=y
CONFIG_INIT_ON_FREE_DEFAULT_ON=y
CONFIG_STRICT_KERNEL_RWX=y
CONFIG_STRICT_DEVMEM=y
CONFIG_SECURITY_DMESG_RESTRICT=y
CONFIG_GCC_PLUGIN_LATENT_ENTROPY=y

# 可选更严格（首次构建建议注释掉，测试稳定后再开启）
CONFIG_GCC_PLUGIN_RANDSTRUCT=y
CONFIG_SECURITY_LOADPIN=y
